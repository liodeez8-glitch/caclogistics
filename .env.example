# ─── SERVER ───────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MONGODB ──────────────────────────────────────────
# Local:   mongodb://localhost:27017/cac_couriers
# Atlas:   mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/cac_couriers
MONGO_URI=mongodb://localhost:27017/cac_couriers

# ─── JWT ──────────────────────────────────────────────
JWT_SECRET=replace_this_with_a_long_random_secret_string_min_32_chars
JWT_EXPIRES_IN=8h

# ─── ADMIN CREDENTIALS (seeded on first run) ──────────
ADMIN_EMAIL=admin@caclogistics.com
ADMIN_PASSWORD=Admin@2024!

# ─── NODEMAILER (Gmail example) ───────────────────────
# For Gmail: enable "App Passwords" in your Google account security settings
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your-gmail@gmail.com
MAIL_PASS=your-gmail-app-password
MAIL_FROM="CAC Couriers & Shipping" <noreply@caclogistics.com>

# Admin notification email (receives contact form submissions & alerts)
ADMIN_NOTIFY_EMAIL=Info@caclogistics.com

# ─── FRONTEND ORIGIN (for CORS) ───────────────────────
# During local dev use: http://localhost:3000 or http://127.0.0.1:5500
# In production use your real domain: https://caclogistics.com
FRONTEND_ORIGIN=http://127.0.0.1:5500

# ─── COMPANY ──────────────────────────────────────────
COMPANY_NAME=CAC Couriers & Shipping Company
TRACKING_BASE_URL=http://127.0.0.1:5500/tracking-result.html
